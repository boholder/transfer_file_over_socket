{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/cmake-build/${presetName}",
      "installDir": "${sourceDir}/cmake-build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/cmake-build/${presetName}",
      "installDir": "${sourceDir}/cmake-build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "x64",
      "hidden": true,
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    },
    {
      "name": "x86",
      "hidden": true,
      "architecture": {
        "value": "x86",
        "strategy": "external"
      }
    },
    {
      "name": "debug",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {"name": "windows-x86-debug", "inherits": ["windows-base", "x86", "debug"]},
    {"name": "windows-x64-debug", "inherits": ["windows-base", "x64", "debug"]},
    {"name": "windows-x86-release", "inherits": ["windows-base", "x86", "release"]},
    {"name": "windows-x64-release", "inherits": ["windows-base", "x64", "release"]},
    {"name": "linux-x86-debug", "inherits": ["linux-base", "x86", "debug"]},
    {"name": "linux-x64-debug", "inherits": ["linux-base", "x64", "debug"]},
    {"name": "linux-x86-release", "inherits": ["linux-base", "x86", "release"]},
    {"name": "linux-x64-release", "inherits": ["linux-base", "x64", "release"]}
  ]
}
